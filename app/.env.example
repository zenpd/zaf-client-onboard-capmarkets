# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
LOG_LEVEL=INFO

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Azure Key Vault (optional) ────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./capmarkets_onboarding.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/capmarkets_onboarding

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=capmarkets-onboarding
TEMPORAL_TASK_QUEUE=capmarkets-onboard-agents

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=capmarkets-onboarding

# ── Platform Integrations ─────────────────────────────────────────────────────
WM_PLATFORM_URL=https://wm-platform.internal/api
CLIENT_MASTER_URL=https://client-master.internal/api
SANCTIONS_API_URL=https://sanctions-api.internal/api
CORE_BANKING_URL=https://core-banking.internal/api
CRM_WEBHOOK_URL=https://crm.internal/webhooks

# ── BRD Thresholds ────────────────────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.85
LLM_CONFIDENCE_THRESHOLD=0.75
AUDIT_RETENTION_YEARS=7
